---
import { formatRupiah } from '../lib/format';

interface Props {
  label: string;
  value: number;
  variant: 'income' | 'expense' | 'balance';
}

const { label, value, variant } = Astro.props;

const valueClass = variant === 'income'
  ? 'text-emerald-500'
  : variant === 'expense'
    ? 'text-red-500'
    : value >= 0 ? 'text-slate-900' : 'text-red-500';
---

<div class="bg-white rounded-xl p-5 border border-slate-200 shadow-sm">
  <p class="text-sm text-slate-500 mb-1">{label}</p>
  <p class={`text-2xl font-semibold ${valueClass}`}>{formatRupiah(value)}</p>
</div>
