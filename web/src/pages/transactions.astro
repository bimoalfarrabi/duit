---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import TransactionRow from '../components/TransactionRow.astro';
import { apiFetch } from '../lib/api';

export const prerender = false;

const token = Astro.locals.token;
const now = new Date();

const month = Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1);
const year = Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const type = Astro.url.searchParams.get('type') ?? '';
const category_id = Astro.url.searchParams.get('category_id') ?? '';
const wallet_id = Astro.url.searchParams.get('wallet_id') ?? '';

type Tx = { id: number; title: string; amount: number; type: 'income' | 'expense'; date: string; category: { name: string }; wallet: { name: string } };
type Category = { id: number; name: string };
type Wallet = { id: number; name: string };

let transactions: Tx[] = [];
let categories: Category[] = [];
let wallets: Wallet[] = [];

try {
  const params = new URLSearchParams({ month: String(month), year: String(year) });
  if (type) params.set('type', type);
  if (category_id) params.set('category_id', category_id);
  if (wallet_id) params.set('wallet_id', wallet_id);

  const [tx, cat, wal] = await Promise.all([
    apiFetch<{ data: Tx[] }>(`/transactions?${params}`, token),
    apiFetch<{ data: Category[] }>('/categories', token),
    apiFetch<{ data: Wallet[] }>('/wallets', token),
  ]);
  transactions = tx.data;
  categories = cat.data;
  wallets = wal.data;
} catch (e) {
  // empty state
}

const monthNames = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
---

<DashboardLayout title="Transaksi">
  <!-- Filter form -->
  <form method="GET" class="flex flex-wrap gap-3 mb-6">
    <div>
      <label class="block text-xs text-slate-500 mb-1">Bulan</label>
      <select name="month" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        {monthNames.map((m, i) => (
          <option value={i + 1} selected={month === i + 1}>{m}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Tahun</label>
      <input name="year" type="number" value={year} min="2020" max="2099"
        class="w-24 px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Tipe</label>
      <select name="type" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <option value="" selected={type === ''}>Semua</option>
        <option value="income" selected={type === 'income'}>Pemasukan</option>
        <option value="expense" selected={type === 'expense'}>Pengeluaran</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Kategori</label>
      <select name="category_id" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <option value="" selected={category_id === ''}>Semua</option>
        {categories.map(c => (
          <option value={c.id} selected={category_id === String(c.id)}>{c.name}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Wallet</label>
      <select name="wallet_id" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <option value="" selected={wallet_id === ''}>Semua</option>
        {wallets.map(w => (
          <option value={w.id} selected={wallet_id === String(w.id)}>{w.name}</option>
        ))}
      </select>
    </div>
    <div class="flex items-end">
      <button type="submit" class="px-4 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium rounded-lg transition-colors">
        Filter
      </button>
    </div>
  </form>

  <!-- Transactions list -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
    {transactions.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-16 text-slate-400">
        <svg class="w-12 h-12 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
        </svg>
        <p class="text-sm font-medium text-slate-500">Belum ada transaksi</p>
        <p class="text-xs text-slate-400 mt-1">Tambah transaksi pertamamu via Android</p>
      </div>
    ) : (
      <div>
        {transactions.map(tx => (
          <TransactionRow
            title={tx.title}
            category={tx.category.name}
            wallet={tx.wallet.name}
            date={tx.date}
            type={tx.type}
            amount={tx.amount}
          />
        ))}
      </div>
    )}
  </div>
</DashboardLayout>
